{
  "name": "sd2sb",
  "version": "0.1.0",
  "description": "Stream Deck plugin for sending SwitchBot API commands.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rollup -c",
    "lint": "eslint .",
    "test": "vitest run",
    "validate": "streamdeck validate org.gakuya.sd2sb.sdPlugin",
    "bundle": "streamdeck pack --force org.gakuya.sd2sb.sdPlugin"
  },
  "dependencies": {
    "@elgato/streamdeck": "2.1.0"
  },
  "devDependencies": {
    "@elgato/cli": "1.7.4",
    "@eslint/js": "9.39.1",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "rollup": "^4.61.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.0",
    "vitest": "^4.1.8"
  }
}
